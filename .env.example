# Copy this file to .env for local testing. On Render, set these in the dashboard (Environment tab).

# Required — your OpenAI API key (starts with sk-...)
OPENAI_API_KEY=

# The OpenAI Realtime voice model. Update to the current realtime model name if this one is retired.
OPENAI_REALTIME_MODEL=gpt-4o-realtime-preview-2024-12-17

# Voice for the assistant (options change over time): alloy, ash, ballad, coral, echo, sage, shimmer, verse
OPENAI_VOICE=verse

# Model used for SMS replies (cheaper text model is fine)
OPENAI_SMS_MODEL=gpt-4o-mini

# Port (Render sets this automatically; default 3000 locally)
PORT=3000
